# Copy into Docker/vault/rendered/rag.env or use Vault KV paths in docs/vault_rag_langfuse_secrets.md

# --- Groq ---
GROQ_API_KEY=
GROQ_MODEL_SMALL=openai/gpt-oss-20b
GROQ_MODEL_LARGE=openai/gpt-oss-120b

# --- Mistral ---
MISTRAL_API_KEY=
MISTRAL_MODEL_SMALL=mistral-small-latest
MISTRAL_MODEL_MEDIUM=mistral-medium-latest
MISTRAL_MODEL_LARGE=mistral-large-latest

# --- LangSearch ---
LANGSEARCH_API_KEY=

# --- Neo4j MCP (LangGraph tools; Basic auth = Neo4j DB user below if MCP_HTTP_* empty) ---
NEO4J_MCP_URL=http://neo4j-mcp:8000/mcp/
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_MCP_HTTP_USER=
NEO4J_MCP_HTTP_PASSWORD=

# --- LangGraph Postgres checkpointer (optional; empty = in-memory only) ---
# postgresql://user:pass@host:5432/dbname?sslmode=disable
CHECKPOINT_POSTGRES_URI=

# --- Langfuse client tracing ---
LANGFUSE_HOST=http://langfuse:3000
# Local dev (app on host, Langfuse in Docker): LANGFUSE_HOST=http://localhost:9507
# Local dev (app on host, MCP published per compose): NEO4J_MCP_URL=http://localhost:9519/mcp/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# SDK 3.x uses OTLP; use true with Docker/langfuse-docker.yaml (Langfuse v3) or Langfuse Cloud.
LANGFUSE_LANGCHAIN_CALLBACKS=true
# Optional: OpenTelemetry service.name in Langfuse (default rag-api).
# OTEL_SERVICE_NAME=rag-api

# --- Compose ports ---
NEO4J_MCP_HOST_PORT=9519
LANGFUSE_HOST_PORT=9507
RAG_API_HOST_PORT=9508
